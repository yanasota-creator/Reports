#!/bin/sh
# Warn (without blocking) when STYLE_GUIDE.md or INDEX.md are part of the push.

empty_tree=4b825dc642cb6eb9a060e54bf8d69288fbee4904
z40=0000000000000000000000000000000000000000
warn=0

while read local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$z40" ] && continue

  if [ "$remote_sha" = "$z40" ]; then
    range="$empty_tree $local_sha"
  else
    range="$remote_sha $local_sha"
  fi

  if git diff --name-only $range -- | grep -E '(^|/)(STYLE_GUIDE|INDEX)\.md$' > /dev/null; then
    warn=1
  fi
done

if [ "$warn" = "1" ]; then
  echo "STYLE_GUIDE.md または INDEX.md に変更があります。Claude.aiのReportsプロジェクトの知識ファイルも忘れずに更新してください。" >&2
fi

exit 0
